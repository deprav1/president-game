# Yandex Metrica counter id. Без значения аналитика работает в режиме no-op
# (в dev события дублируются в console). Скопируйте в .env и подставьте свой id.
VITE_YM_ID=

# Оценка карточек игроками (тест-период): 1 — показывать значки 👍/👎 снизу карты
# и слать событие card_rate в аналитику. Пусто/0 — значков нет. После теста уберите.
VITE_RATING_ENABLED=
