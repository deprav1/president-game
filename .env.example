# Yandex Metrica counter id. Без значения аналитика работает в режиме no-op
# (в dev события дублируются в console). Скопируйте в .env и подставьте свой id.
VITE_YM_ID=

# Оценка карточек игроками (тест-период): 1 — показывать значки 👍/👎 снизу карты
# и слать событие card_rate в аналитику. Пусто/0 — значков нет. После теста уберите.
VITE_RATING_ENABLED=

# Optional server collector for the internal admin dashboard.
# Example: https://admin.example.com/api/collect
VITE_ANALYTICS_ENDPOINT=

# Telegram-ник админа, которому доступна внутриигровая панель аналитики.
# По умолчанию deprav. Вход также возможен через ?admin=<ник> (dev/браузер).
VITE_ADMIN_USERNAME=deprav

# Необязательно: прямой URL дашборда admin-server для сводки в панели.
# Если пусто — выводится из VITE_ANALYTICS_ENDPOINT (.../api/collect → .../api/dashboard).
VITE_ANALYTICS_DASHBOARD=

# Общая (глобальная) таблица рекордов. URL POST/GET endpoint'а admin-server.
# Example: https://admin.example.com/api/leaderboard
# Если пусто — выводится из VITE_ANALYTICS_ENDPOINT (.../api/collect → .../api/leaderboard).
# Совсем без обоих — глобальный рейтинг выключен, работает только личная доска.
VITE_LEADERBOARD_ENDPOINT=

# Server-side admin dashboard env (do not expose these in Vite client builds).
ADMIN_PORT=3100
ADMIN_USER=admin
ADMIN_PASSWORD=
YANDEX_COUNTER_ID=109695119
YANDEX_METRICA_TOKEN=
# ВАЖНО для глобальной доски рекордов: список разрешённых origin через запятую
# (напр. https://cb077728.tw1.ru). Пусто или "*" = принимать POST-результаты
# с ЛЮБОГО сайта. Для прод-доски обязательно укажите origin мини-аппа.
ANALYTICS_ALLOWED_ORIGIN=
